PORT=4000
PAYMENT_LINK_BASE=http://localhost:3000

# Supabase (service role key is required for server-side inserts)
SUPABASE_URL=your_supabase_url
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key

# Stellar config
STELLAR_NETWORK=testnet
STELLAR_HORIZON_URL=

# Optional asset issuers
USDC_ISSUER=your_usdc_issuer

# Webhook signing – shared secret used to produce Stellar-Signature: sha256=<hmac>
# Generate a strong random value, e.g.: openssl rand -hex 32
WEBHOOK_SECRET=your_webhook_secret

# CORS configuration – comma-separated list of allowed origins
# Example: CORS_ALLOWED_ORIGINS=http://localhost:3000,https://yourdomain.com
CORS_ALLOWED_ORIGINS=http://localhost:3000
